generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  USER
  ADMIN
}

model User {
  id           String    @id @default(cuid())
  email        String    @unique
  passwordHash String
  name         String
  role         Role      @default(USER)
  /// When set, the user is banned — login is refused and game access blocked.
  bannedAt     DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  empire Empire?
}

/// Single-row (`id = "singleton"`) table holding admin-editable global game
/// balance. `data` is a JSON overlay merged over DEFAULT_TUNABLES in code —
/// see src/lib/game/config.ts.
model GameConfig {
  id        String   @id @default("singleton")
  data      Json     @default("{}")
  updatedAt DateTime @updatedAt
}

enum MiniGameType {
  GUESS_NUMBER
  FIND_BALL
}

/// An admin-authored mini-game event (guess-the-number / find-the-ball). When
/// `isActive`, it shows as a live bar at the top of every player's screen and
/// grants the prize bundle to winners. `config` holds the secret answer +
/// public params ({min,max,answer} or {cups,answer}) — never send answer to
/// the client.
model MiniGameEvent {
  id           String       @id @default(cuid())
  type         MiniGameType
  title        String
  config       Json
  maxAttempts  Int          @default(5)
  /// 0 = unlimited winners.
  maxWinners   Int          @default(0)
  winnersCount Int          @default(0)
  isActive     Boolean      @default(false)

  prizeGold       Float @default(0)
  prizeWood       Float @default(0)
  prizeIron       Float @default(0)
  prizeStone      Float @default(0)
  prizeDiamonds   Float @default(0)
  prizeCitizens   Int   @default(0)
  prizeTurns      Int   @default(0)
  prizeWheelSpins Int   @default(0)

  createdAt   DateTime  @default(now())
  activatedAt DateTime?
  endedAt     DateTime?
  updatedAt   DateTime  @updatedAt

  entries MiniGameEntry[]

  @@index([isActive])
}

/// One player's participation in a mini-game event (attempts + win state).
model MiniGameEntry {
  id        String    @id @default(cuid())
  eventId   String
  empireId  String
  attempts  Int       @default(0)
  solved    Boolean   @default(false)
  won       Boolean   @default(false)
  wonAt     DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  event MiniGameEvent @relation(fields: [eventId], references: [id], onDelete: Cascade)

  @@unique([eventId, empireId])
  @@index([eventId])
}

/// Append-only trail of every mutating admin action, for accountability.
model AdminAuditLog {
  id         String   @id @default(cuid())
  adminId    String
  adminEmail String
  action     String
  /// e.g. "empire", "user", "season", "guild", "broadcast", "config".
  targetType String?
  targetId   String?
  /// Human-readable summary shown in the audit log UI.
  summary    String?
  details    Json?
  createdAt  DateTime @default(now())

  @@index([createdAt])
  @@index([adminId])
}

model GameSeason {
  id        String   @id @default(cuid())
  name      String
  startsAt  DateTime
  endsAt    DateTime
  isActive  Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  empires Empire[]
}

model Empire {
  id                  String   @id @default(cuid())
  userId              String   @unique
  seasonId            String?
  name                String   @unique
  level               Int      @default(1)
  gold                Float    @default(2000)
  wood                Float    @default(1500)
  iron                Float    @default(1000)
  stone               Float    @default(1000)
  diamonds            Float    @default(10)
  citizens            Int      @default(50)
  /// Cities the empire holds (1..MAX_CITIES). Each city adds 100 to the
  /// citizen capacity, so ten cities ceiling the population at 1,000.
  cities              Int      @default(1)
  turns               Int      @default(0)
  /// Remaining wheel-of-fortune spins. Consumed on each spin, topped up on
  /// every daily update (capped) — see WHEEL_DAILY_SPINS / WHEEL_SPINS_CAP.
  wheelSpins          Int      @default(4)
  lastRegularUpdateAt DateTime @default(now())
  lastDailyUpdateAt   DateTime @default(now())
  /// Last time the player opened the reports page — drives the "new reports" badge.
  reportsSeenAt       DateTime @default(now())
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  user          User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  season        GameSeason?          @relation(fields: [seasonId], references: [id], onDelete: SetNull)
  buildings     Building[]
  army          Army?
  storages      ResourceStorage[]
  upgrades      EmpireUpgrade[]
  bankAccount   BankAccount?
  weapons       EmpireWeapon[]
  weaponUnlocks EmpireWeaponUnlock[]
  hero          Hero?

  spyReportsSent     SpyReport[]    @relation("SpyAttacker")
  spyReportsReceived SpyReport[]    @relation("SpyDefender")
  battlesAttacked    BattleReport[] @relation("BattleAttacker")
  battlesDefended    BattleReport[] @relation("BattleDefender")
  messages           Message[]
  guildMembership    GuildMember?
  guildBuffs         GuildSpellBuff[]
  diamondEffects     DiamondEffect[]
  diamondPurchases   DiamondPurchase[]
}

/* --------------------------- diamond store (real money) --------------------------- */

/// Lifecycle of a real-money diamond-package purchase.
enum PurchaseStatus {
  /// Charge created with the provider, not yet confirmed.
  PENDING
  /// Charge succeeded and the diamonds were credited.
  PAID
  /// Charge failed or was declined — no diamonds credited.
  FAILED
}

/// One real-money purchase attempt of a diamond package — a full financial
/// audit row. Created PENDING, then settled to PAID (diamonds credited in the
/// same transaction) or FAILED by the payment provider result.
///
/// Everything needed to read a receipt is snapshotted at purchase time, because
/// (a) packages live in code (DIAMOND_PACKAGES), not in rows, and (b) the buyer
/// or their empire may later be renamed or deleted. `empireId` is therefore
/// nullable with onDelete: SetNull — deleting an account never erases its
/// purchase history. `isTest` marks charges that moved no real money (the mock
/// provider), so real revenue can be reported separately.
model DiamondPurchase {
  id           String         @id @default(cuid())
  empireId     String?
  /// Snapshot of the buyer's user id (survives empire/account deletion).
  userId       String?
  /// Snapshot of the buyer's email at purchase time (for receipts/support).
  userEmail    String?
  /// Snapshot of the empire name at purchase time.
  empireName   String?
  /// Package id from DIAMOND_PACKAGES.
  packageId    String
  /// Total diamonds granted (base + bonus), snapshotted at purchase time.
  diamonds     Int
  /// Base diamonds of the package (without the bonus).
  baseDiamonds Int            @default(0)
  /// Bonus diamonds thrown in on top.
  bonusDiamonds Int           @default(0)
  /// Price actually charged, after any admin discount.
  priceIls     Float
  /// Full list price before the admin discount (for the receipt).
  basePriceIls Float          @default(0)
  /// Discount percent applied at purchase time.
  discountPct  Float          @default(0)
  /// ISO-4217 currency of the charge.
  currency     String         @default("ILS")
  /// Payment provider that handled the charge ("mock" until a real one is wired).
  provider     String
  /// Provider-side transaction reference, once charged.
  providerRef  String?
  /// True when no real money moved (mock provider / admin test purchase).
  isTest       Boolean        @default(false)
  status       PurchaseStatus @default(PENDING)
  /// Why the charge failed (only set on FAILED).
  failureReason String?
  /// When the charge settled as PAID.
  paidAt       DateTime?
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt

  empire Empire? @relation(fields: [empireId], references: [id], onDelete: SetNull)

  @@index([empireId])
  @@index([userId])
  @@index([status])
  @@index([createdAt])
}

/* ------------------------------ diamond shop ------------------------------ */

/// A purchasable diamond effect on an empire. Timed buffs (resource boosts,
/// shop discount) use `magnitude` + `activeUntil`; cooldown-only spells
/// (bank interest) use `readyAt`. One row per (empire, kind).
enum DiamondEffectKind {
  RESOURCE_BOOST_GOLD
  RESOURCE_BOOST_WOOD
  RESOURCE_BOOST_IRON
  RESOURCE_BOOST_STONE
  SHOP_DISCOUNT
  BANK_INTEREST
  CITY_SIEGE
  TURN_PACK_1
  TURN_PACK_2
  TURN_PACK_3
  TURN_PACK_4
}

model DiamondEffect {
  id          String            @id @default(cuid())
  empireId    String
  kind        DiamondEffectKind
  /// Boost/discount percent (0 for cooldown-only spells).
  magnitude   Float             @default(0)
  /// When a timed buff expires (null for cooldown-only spells).
  activeUntil DateTime?
  /// When a cooldown-only spell becomes usable again (null for buffs).
  readyAt     DateTime?
  updatedAt   DateTime          @updatedAt
  createdAt   DateTime          @default(now())

  empire Empire @relation(fields: [empireId], references: [id], onDelete: Cascade)

  @@unique([empireId, kind])
  @@index([empireId, activeUntil])
}

/* ------------------------------ guilds ------------------------------ */

enum GuildRole {
  LEADER
  DEPUTY
  MEMBER
}

/// The four guild spells sold in the guild shop. Each has a per-guild level
/// (level = bonus %, starts at 1, capped at 20) that members upgrade with
/// diamonds; casting one grants the caster a 24h personal buff.
enum GuildSpellType {
  ATTACK
  DEFENSE
  SPY
  RESOURCES
}

model Guild {
  id            String   @id @default(cuid())
  name          String   @unique
  /// Shared gold treasury — members deposit and withdraw freely.
  goldBalance   Float    @default(0)
  /// Member capacity = 1 + level, so a fresh guild (level 1) holds 2 members.
  capacityLevel Int      @default(1)
  /// Guild aid level — each level adds 1% of the guild's total military power
  /// as flat combat power for every member in battle, up to 10%. Bought with
  /// treasury gold.
  aidLevel      Int      @default(0)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  members      GuildMember[]
  spells       GuildSpell[]
  transactions GuildBankTransaction[]
}

model GuildMember {
  id        String    @id @default(cuid())
  guildId   String
  empireId  String    @unique
  role      GuildRole @default(MEMBER)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  guild  Guild  @relation(fields: [guildId], references: [id], onDelete: Cascade)
  empire Empire @relation(fields: [empireId], references: [id], onDelete: Cascade)

  @@index([guildId])
}

model GuildSpell {
  id        String         @id @default(cuid())
  guildId   String
  type      GuildSpellType
  level     Int            @default(1)
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt

  guild Guild @relation(fields: [guildId], references: [id], onDelete: Cascade)

  @@unique([guildId, type])
}

/// An active (or expired, until cleaned up) 24h spell buff on an empire.
/// The bonus % is snapshotted at cast time.
model GuildSpellBuff {
  id        String         @id @default(cuid())
  empireId  String
  type      GuildSpellType
  bonusPct  Float
  expiresAt DateTime
  createdAt DateTime       @default(now())

  empire Empire @relation(fields: [empireId], references: [id], onDelete: Cascade)

  @@index([empireId, expiresAt])
}

enum GuildBankTransactionType {
  DEPOSIT
  WITHDRAW
}

model GuildBankTransaction {
  id           String                   @id @default(cuid())
  guildId      String
  empireId     String
  /// Denormalized so the ledger stays readable if the member leaves.
  empireName   String
  type         GuildBankTransactionType
  amount       Float
  balanceAfter Float
  createdAt    DateTime                 @default(now())

  guild Guild @relation(fields: [guildId], references: [id], onDelete: Cascade)

  @@index([guildId, createdAt])
}

enum MessageKind {
  SYSTEM
  BATTLE
  SPY
}

/// Inbox message for an empire — system announcements and combat alerts
/// ("you were attacked", "a spy was caught in your territory").
model Message {
  id        String      @id @default(cuid())
  empireId  String
  kind      MessageKind @default(SYSTEM)
  title     String
  body      String
  /// Optional in-game link, e.g. the full battle report page.
  href      String?
  readAt    DateTime?
  createdAt DateTime    @default(now())

  empire Empire @relation(fields: [empireId], references: [id], onDelete: Cascade)

  @@index([empireId, readAt])
  @@index([empireId, createdAt])
}

enum HeroRarity {
  COMMON
  RARE
  EPIC
  LEGENDARY
}

enum HeroItemSlot {
  SWORD
  GAUNTLETS
  WINGS
  HELMET
  ARMOR
  SHIELD
  PANTS
  BOOTS
  RELIC
}

model Hero {
  id             String   @id @default(cuid())
  empireId       String   @unique
  level          Int      @default(1)
  xp             Int      @default(0)
  unspentPoints  Int      @default(0)
  attackPoints   Int      @default(0)
  defensePoints  Int      @default(0)
  resourcePoints Int      @default(0)
  resets         Int      @default(0)
  /// The season in which the diamond points-reset was last used (once/season).
  pointsResetSeasonId String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  empire Empire     @relation(fields: [empireId], references: [id], onDelete: Cascade)
  items  HeroItem[]
}

model HeroItem {
  id        String       @id @default(cuid())
  heroId    String
  slot      HeroItemSlot
  level     Int
  rarity    HeroRarity
  equipped  Boolean      @default(false)
  createdAt DateTime     @default(now())

  hero Hero @relation(fields: [heroId], references: [id], onDelete: Cascade)

  @@index([heroId])
}

enum BuildingType {
  GOLD_MINE
  WOOD_CAMP
  IRON_MINE
  STONE_QUARRY
  BARRACKS
  SPY_CENTER
}

model Building {
  id             String       @id @default(cuid())
  empireId       String
  type           BuildingType
  level          Int          @default(1)
  slavesAssigned Int          @default(0)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  empire Empire @relation(fields: [empireId], references: [id], onDelete: Cascade)

  @@unique([empireId, type])
}

model Army {
  id         String   @id @default(cuid())
  empireId   String   @unique
  soldiers   Int      @default(0)
  spies      Int      @default(0)
  mineSlaves Int      @default(0)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  empire Empire @relation(fields: [empireId], references: [id], onDelete: Cascade)
}

enum ResourceStorageType {
  GOLD
  WOOD
  IRON
  STONE
}

model ResourceStorage {
  id           String              @id @default(cuid())
  empireId     String
  resourceType ResourceStorageType
  level        Int                 @default(1)
  storedAmount Float               @default(0)
  createdAt    DateTime            @default(now())
  updatedAt    DateTime            @updatedAt

  empire Empire @relation(fields: [empireId], references: [id], onDelete: Cascade)

  @@unique([empireId, resourceType])
}

enum EmpireUpgradeType {
  CITIZEN_GROWTH
  DIAMOND_YIELD
  INTELLIGENCE
  BANK_DEPOSIT_COUNT
  BANK_DAILY_INTEREST
  TURNS_PER_REGULAR_UPDATE
  WHEEL_LUCK
}

model EmpireUpgrade {
  id        String            @id @default(cuid())
  empireId  String
  type      EmpireUpgradeType
  level     Int               @default(1)
  createdAt DateTime          @default(now())
  updatedAt DateTime          @updatedAt

  empire Empire @relation(fields: [empireId], references: [id], onDelete: Cascade)

  @@unique([empireId, type])
}

enum WeaponCategory {
  ATTACK
  DEFENSE
  SPY
}

model EmpireWeapon {
  id        String   @id @default(cuid())
  empireId  String
  weaponKey String
  quantity  Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  empire Empire @relation(fields: [empireId], references: [id], onDelete: Cascade)

  @@unique([empireId, weaponKey])
}

model EmpireWeaponUnlock {
  id           String         @id @default(cuid())
  empireId     String
  category     WeaponCategory
  unlockedTier Int            @default(2)
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt

  empire Empire @relation(fields: [empireId], references: [id], onDelete: Cascade)

  @@unique([empireId, category])
}

model BankAccount {
  id                          String   @id @default(cuid())
  empireId                    String   @unique
  goldBalance                 Float    @default(0)
  depositsUsedInCurrentPeriod Int      @default(0)
  depositPeriodStartedAt      DateTime @default(now())
  createdAt                   DateTime @default(now())
  updatedAt                   DateTime @updatedAt

  empire       Empire            @relation(fields: [empireId], references: [id], onDelete: Cascade)
  transactions BankTransaction[]
}

enum BankTransactionType {
  DEPOSIT
  WITHDRAW
  INTEREST
}

model BankTransaction {
  id            String              @id @default(cuid())
  bankAccountId String
  empireId      String
  type          BankTransactionType
  amount        Float
  balanceAfter  Float
  createdAt     DateTime            @default(now())

  bankAccount BankAccount @relation(fields: [bankAccountId], references: [id], onDelete: Cascade)

  @@index([empireId, createdAt])
}

model SpyReport {
  id                 String   @id @default(cuid())
  attackerEmpireId   String
  defenderEmpireId   String
  success            Boolean
  revealedGold       Float?
  revealedWood       Float?
  revealedIron       Float?
  revealedStone      Float?
  revealedSoldiers   Int?
  revealedSpies      Int?
  revealedMineSlaves Int?
  finalChance        Float?
  weaponsBonus       Float?
  /// Percentage points the attacker's guild spy buff added to the chance.
  guildBonus         Float?
  /// Attacker's effective intelligence power at resolution (deterministic spy).
  attackerIntel      Float?
  /// Defender's effective intelligence power at resolution (deterministic spy).
  defenderIntel      Float?
  turnsSpent         Int      @default(5)
  createdAt          DateTime @default(now())

  attackerEmpire Empire @relation("SpyAttacker", fields: [attackerEmpireId], references: [id], onDelete: Cascade)
  defenderEmpire Empire @relation("SpyDefender", fields: [defenderEmpireId], references: [id], onDelete: Cascade)
}

model BattleReport {
  id                   String   @id @default(cuid())
  attackerEmpireId     String
  defenderEmpireId     String
  attackerPower        Float
  defenderPower        Float
  attackerSoldiersPower Float?
  attackerWeaponsPower  Float?
  defenderSoldiersPower Float?
  defenderWeaponsPower  Float?
  winnerEmpireId       String
  attackerSoldiersLost Int
  defenderSoldiersLost Int
  // Defender soldiers captured by a winning attacker — they join the
  // attacker's free mine-slave pool.
  enslavedSoldiers     Int      @default(0)
  stolenGold           Float
  stolenWood           Float
  stolenIron           Float
  stolenStone          Float
  turnsSpent           Int      @default(10)
  createdAt            DateTime @default(now())

  // Hero: battle XP awarded to each side and the % power bonus each hero added.
  attackerHeroBonusPct Float?
  defenderHeroBonusPct Float?

  // Guild spells: % power bonus each side's active buff added (attack buff
  // for the attacker, defense buff for the defender).
  attackerGuildBonusPct Float?
  defenderGuildBonusPct Float?
  attackerHeroXp       Int      @default(0)
  defenderHeroXp       Int      @default(0)

  // Hero item captured by the attacker on a win (denormalized snapshot).
  droppedItemSlot   HeroItemSlot?
  droppedItemLevel  Int?
  droppedItemRarity HeroRarity?

  // A winning attack can also award a wheel-of-fortune spin (wheel-luck upgrade).
  wonWheelSpin      Boolean  @default(false)

  attackerEmpire Empire @relation("BattleAttacker", fields: [attackerEmpireId], references: [id], onDelete: Cascade)
  defenderEmpire Empire @relation("BattleDefender", fields: [defenderEmpireId], references: [id], onDelete: Cascade)
}
